# ============================================
# KedaiKopi Production Configuration
# ============================================

# REQUIRED — Generate with: docker compose exec backend php artisan key:generate --show
APP_KEY=

# REQUIRED — Database passwords
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_2024
DB_DATABASE=kedaikopi
DB_USERNAME=kedaikopi
DB_PASSWORD=CHANGE_ME_DB_PASSWORD_2024

# App settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://kedaikopi.id
FRONTEND_URL=https://kedaikopi.id
FRONTEND_PORT=80

# Sanctum
SANCTUM_STATEFUL_DOMAINS=kedaikopi.id,www.kedaikopi.id

# Logging
LOG_LEVEL=warning

# Mail (choose one)
MAIL_MAILER=log
# For Resend:
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxx
MAIL_FROM_ADDRESS=noreply@kedaikopi.id
